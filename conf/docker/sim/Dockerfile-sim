# Environnement de SIMULATION (x86, PC de dev) : Gazebo Harmonic + outils.
# Le vrai Didier peut rester éteint pendant qu'on travaille ici.
FROM ros:jazzy-ros-base
LABEL authors="dadouuu"

# ros-jazzy-ros-gz installe Gazebo Harmonic (paire officielle de Jazzy)
# via les paquets vendored de packages.ros.org — pas de dépôt en plus.
RUN apt-get update && apt-get install -y \
    ros-jazzy-ros-gz \
    ros-jazzy-xacro \
    ros-jazzy-robot-state-publisher \
    ros-jazzy-joint-state-publisher-gui \
    ros-jazzy-rviz2 \
    ros-jazzy-teleop-twist-keyboard \
    ros-jazzy-twist-mux \
    python3-pip \
    python3-aiohttp \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/ros2_ws/src
WORKDIR /home/ros2_ws

# Les sources sont aussi montées en volume par le compose (itération sans
# rebuild) ; la copie permet de lancer l'image seule.
COPY conf/ros2_dependencies/robot_description /home/ros2_ws/src/robot_description
COPY conf/ros2_dependencies/robot_sim /home/ros2_ws/src/robot_sim
COPY conf/ros2_dependencies/robot_interfaces /home/ros2_ws/src/robot_interfaces
COPY conf/ros2_dependencies/robot_drive /home/ros2_ws/src/robot_drive
COPY conf/ros2_dependencies/robot_web /home/ros2_ws/src/robot_web
COPY conf/scripts/launch-sim-in-docker.sh /home/ros2_ws/

# json/ : robot_lights.json, lights_base.json, colors.json lus par leds_sim_node
# (mêmes fichiers que le vrai robot, cf. robot/robot_config.py) pour que la visu
# LED en sim résolve les mêmes séquences/couleurs. Monté aussi en volume par le
# compose (itération sans rebuild), comme les paquets ros2_dependencies.
COPY json/ /home/ros2_ws/json/

# --- Paquet "robot" (animations_node, param animations:=true du launch sim) ---
# Rejoue les séquences JSON (json/sequences/**) dans la sim : servos + faces +
# LED via les topics StringTime déjà consommés par servos_sim_node/leds_sim_node.
# Reproduit EXACTEMENT la mécanique de déploiement Ansible sur le vrai robot
# (dadou_utils_ros/ansible/roles/synchronise) : le paquet ROS ament_python
# "robot" (setup.py) est la RACINE du repo synchronisée dans ros2_ws/src/robot/,
# où cohabitent le module Python robot/ ET le module dadou_utils_ros/ (tous deux
# ont un __init__.py -> setup.py les trouve avec find_packages()). Investigation
# menée avant d'écrire ces lignes (cf. CLAUDE.md/commit) : la chaîne d'imports
# RÉELLEMENT parcourue par animations_node (robot_config, RobotJsonManager,
# AnimationManager, abstract_json_actions, animation, random_animation_start,
# + le sous-ensemble de dadou_utils_ros qu'ils importent) ne touche AUCUNE lib
# matérielle (adafruit_*, RPi.GPIO, board...) -- celles-ci ne sont importées
# QUE par robot/actions/servo.py, robot/actions/lights.py etc. (jamais chargés
# ici). Seules 3 libs pures manquent à l'image ROS de base : filetype (utilisé
# par dadou_utils_ros.misc au niveau module) et colorlog/psutil (utilisés par
# logging_conf / d'autres modules dadou_utils_ros importés transitivement).
# medias/ et db/ ne sont PAS nécessaires : RobotJsonManager/AnimationManager ne
# lisent que du JSON sous json/ (pas d'accès fichier audio/DB dans ce chemin).
#
# dadou_utils_ros/ n'est PAS copié ici (contrairement à robot/) : à la racine
# du repo c'est un SYMLINK vers ../dadou_utils_ros (dépôt frère), qui sort du
# contexte de build (context: ../../.. dans docker-compose-sim.yml = racine du
# repo). BuildKit ne le suit pas (testé : `COPY dadou_utils_ros/ ...` échoue
# avec "too many links" -- le sender de contexte n'inclut pas le contenu hors
# contexte, contrairement à `copy_links: yes` côté Ansible qui, lui, déréférence
# vraiment le symlink). Sur le builder Jenkins (conf/docker/arm/Dockerfile-arm,
# même COPY), ça fonctionne car dadou_utils_ros y est un checkout git réel,
# pas un symlink (cf. Jenkinsfile : clone séparé à ce chemin exact). En sim,
# le contenu arrive UNIQUEMENT via le volume docker-compose (qui pointe le
# vrai chemin hôte, en contournant le symlink) -- voir docker-compose-sim.yml.
# Conséquence assumée : l'image seule (sans compose) n'a pas dadou_utils_ros ;
# le workflow de ce projet ne lance de toute façon jamais l'image en `docker
# run` nu (toujours `docker compose ... up`, cf. CLAUDE.md).
COPY robot/ /home/ros2_ws/src/robot/robot/
COPY conf/ros2/setup.py conf/ros2/package.xml conf/ros2/setup.cfg /home/ros2_ws/src/robot/
COPY conf/ros2/resource/ /home/ros2_ws/src/robot/resource/
# JSON_DIRECTORY résolu par robot/robot_config.py = <PROJECT_DIRECTORY>/json/
# où PROJECT_DIRECTORY="/home/ros2_ws/src/robot/" (chemin DIFFÉRENT de la copie
# json/ ci-dessus, dédiée à leds_sim_node) : les séquences vivent sous json/sequences/.
COPY json/ /home/ros2_ws/src/robot/json/
# log/ : logging_conf.py écrit un TimedRotatingFileHandler sur ce chemin exact
# (robot_config.LOGGING_FILE_NAME) -- le dossier doit exister avant le premier
# `logging.config.dictConfig(...)` (fait dans AnimationsNode.__init__), sinon
# le node meurt à l'instanciation (FileNotFoundError).
RUN mkdir -p /home/ros2_ws/log

# filetype/colorlog/psutil : seules dépendances pip RÉELLEMENT requises par la
# chaîne d'imports d'animations_node (cf. investigation ci-dessus) -- pas tout
# requirements.txt (adafruit-*, PyAudio... inutiles ici et lourds à builder).
# --break-system-packages : Ubuntu Noble (Jazzy) refuse pip hors venv sans ce
# flag (même contournement que conf/docker/arm/Dockerfile-arm).
RUN pip3 install --no-cache-dir --break-system-packages filetype colorlog psutil

ENTRYPOINT ["/bin/bash", "-c", "/home/ros2_ws/launch-sim-in-docker.sh"]
