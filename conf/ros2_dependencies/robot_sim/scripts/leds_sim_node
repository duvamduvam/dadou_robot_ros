#!/usr/bin/env python3
"""Node de visualisation LED en simulation Gazebo (paquet robot_sim, AUTONOME :
aucun import de robot.* ni dadou_utils_ros, même règle que robot_drive).

AVERTISSEMENT : ceci est une VISUALISATION, pas une réplique du rendu Adafruit
LED Animation du vrai robot -- voir robot_sim_lib/leds_logic.py pour le détail
des approximations (effets, "face"). Le but est un repère visuel en sim, pas
une validation du rendu physique du ruban.

Mécanisme : le monde `stage` (robot_sim/worlds/stage.sdf) charge le système gz
UserCommands, qui expose /world/stage/material_color (gz.msgs.MaterialColor).
Le bridge ros_gz (config/gz_bridge.yaml) route notre topic ROS /material_color
dessus : publier dessus change en direct le matériau (diffuse/emissive) d'un
visual nommé, sans reconstruire la scène. Voir CLAUDE.md / commit de la
bascule cmd_vel pour le même principe appliqué au bridge topics roues.

Abonnements :
  - robot_lights (StringTime) : nom de séquence (json/robot_lights.json), ou
    "stop", ou {"brightness": x}. Cible body_leds_link_visual.
  - face (StringTime) : nom d'expression, ou "stop". Cible mouth_leds_link_visual
    + left_eye_link_visual + right_eye_link_visual (approximation V1, voir
    leds_logic.face_colors).

Timer 10 Hz : calcule la couleur courante et publie un MaterialColor par
visual, mais SEULEMENT si elle a changé depuis le dernier tick -- le topic gz
est une commande utilisateur (UserCommands), pas un flux vidéo, spammer dessus
n'a pas de sens. Exception : les effets "animés" (blink/pulse/sparkle/rainbow/
color_cycle) changent à chaque tick par nature, donc on les publie toujours
(cf. leds_logic.is_animated_method).
"""
import json
import os
import sys

# Bootstrap d'import : le script et robot_sim_lib sont installés côte à côte
# dans lib/robot_sim/ (voir CMakeLists.txt -- ament_cmake n'a pas de mécanisme
# ament_python pour "juste" installer un module Python sur le PYTHONPATH).
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from robot_sim_lib.leds_logic import (  # noqa: E402
    LedsSimState,
    face_colors,
    is_animated_method,
)

import rclpy  # noqa: E402
from rclpy.node import Node  # noqa: E402
from robot_interfaces.msg import StringTime  # noqa: E402
from ros_gz_interfaces.msg import Entity, MaterialColor  # noqa: E402

# Noms des visuals dans la scène gz (cf. dadou_robot_gz.urdf.xacro : joints
# fixes protégés par preserveFixedJoint pour garder un nom <link>_visual
# stable ; les yeux sont sur des joints MOBILES, déjà nommés ainsi nativement).
BODY_LEDS_VISUAL = "body_leds_link_visual"
MOUTH_LEDS_VISUAL = "mouth_leds_link_visual"
LEFT_EYE_VISUAL = "left_eye_link_visual"
RIGHT_EYE_VISUAL = "right_eye_link_visual"

VISUAL_ENTITY_TYPE = Entity.VISUAL  # = 4

# Ambient sombre : garde un semblant de matière même LED éteinte (évite un
# visual totalement plat / noir mat qui masque la géométrie en sim).
AMBIENT_DARK = (0.02, 0.02, 0.02)

DEFAULT_JSON_DIR = "/home/ros2_ws/json"


class LedsSimNode(Node):

    def __init__(self):
        super().__init__("leds_sim_node")

        self.declare_parameter("robot_lights_json", os.path.join(DEFAULT_JSON_DIR, "robot_lights.json"))
        self.declare_parameter("lights_base_json", os.path.join(DEFAULT_JSON_DIR, "lights_base.json"))
        self.declare_parameter("colors_json", os.path.join(DEFAULT_JSON_DIR, "colors.json"))

        robot_lights = self._load_json(self.get_parameter("robot_lights_json").value)
        self.lights_base = self._load_json(self.get_parameter("lights_base_json").value)
        self.colors = self._load_json(self.get_parameter("colors_json").value)

        self.state = LedsSimState(robot_lights)
        self._face_expression = None  # dernière expression reçue sur `face` (ou None/"stop")
        self._last_published = {}    # visual_name -> dernier RGB publié (anti-spam)

        self.material_color_pub = self.create_publisher(MaterialColor, "/material_color", 10)

        self.create_subscription(StringTime, "robot_lights", self._on_robot_lights, 10)
        self.create_subscription(StringTime, "face", self._on_face, 10)

        # 10 Hz : largement suffisant pour une visu, pas un rendu temps réel fidèle.
        self.create_timer(0.1, self._on_timer)

        self.get_logger().info(
            "leds_sim_node démarré (visualisation LED en sim, pas le rendu réel)")

    @staticmethod
    def _load_json(path):
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)

    def _now_ms(self):
        # Horloge ROS (sim_time si use_sim_time:=true, bridgée depuis gz /clock) :
        # jamais time.time(), sinon la visu dérive de l'horloge de simulation.
        return self.get_clock().now().nanoseconds // 1_000_000

    # ---- callbacks messages (une ligne de log par CHANGEMENT, pas par tick) ----

    def _on_robot_lights(self, msg):
        try:
            payload = json.loads(msg.msg)
        except json.JSONDecodeError:
            self.get_logger().error('robot_lights: JSON invalide : "{}"'.format(msg.msg))
            return
        override = msg.time if msg.time else None
        try:
            self.state.update(payload, self._now_ms(), override_duration_ms=override)
        except KeyError:
            self.get_logger().error('robot_lights: séquence inconnue : "{}"'.format(payload))
            return
        self.get_logger().info('robot_lights: "{}"'.format(payload))

    def _on_face(self, msg):
        try:
            expression = json.loads(msg.msg)
        except json.JSONDecodeError:
            self.get_logger().error('face: JSON invalide : "{}"'.format(msg.msg))
            return
        self._face_expression = expression
        self.get_logger().info('face: "{}"'.format(expression))

    # ---- timer 10 Hz : calcule + publie (avec anti-spam) ----

    def _on_timer(self):
        now_ms = self._now_ms()

        body_color, method = self.state.current_color_and_method(now_ms, self.lights_base, self.colors)
        self._publish_material(BODY_LEDS_VISUAL, body_color, force=is_animated_method(method))

        face = face_colors(self._face_expression, self.colors)
        self._publish_material(MOUTH_LEDS_VISUAL, face["mouth"], force=False)
        self._publish_material(LEFT_EYE_VISUAL, face["left_eye"], force=False)
        self._publish_material(RIGHT_EYE_VISUAL, face["right_eye"], force=False)

    def _publish_material(self, visual_name, rgb, force):
        rgb = rgb if rgb is not None else (0, 0, 0)
        if not force and self._last_published.get(visual_name) == rgb:
            return  # anti-spam : /material_color est une commande gz, pas un flux
        self._last_published[visual_name] = rgb

        r, g, b = (channel / 255.0 for channel in rgb)

        material = MaterialColor()
        material.entity.name = visual_name
        material.entity.type = VISUAL_ENTITY_TYPE
        material.entity_match = MaterialColor.FIRST
        material.diffuse.r, material.diffuse.g, material.diffuse.b, material.diffuse.a = r, g, b, 1.0
        material.emissive.r, material.emissive.g, material.emissive.b, material.emissive.a = r, g, b, 1.0
        ar, ag, ab = AMBIENT_DARK
        material.ambient.r, material.ambient.g, material.ambient.b, material.ambient.a = ar, ag, ab, 1.0

        self.material_color_pub.publish(material)


def main(args=None):
    rclpy.init(args=args)
    node = LedsSimNode()
    try:
        rclpy.spin(node)
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
