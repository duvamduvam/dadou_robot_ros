<?xml version="1.0"?>
<!--
  Extension Gazebo (gz-sim / Harmonic) du robot Dadou.

  Inclut l'URDF nominal (dadou_robot.urdf.xacro, inchangé : il reste la
  description commune vrai robot / RViz / sim) et y ajoute uniquement ce
  qui n'existe qu'en simulation :
   - plugin DiffDrive : consomme /cmd_vel (Twist), publie /odom + TF.
     C'est LE premier consommateur de l'interface standard cmd_vel —
     le vrai wheels_node migrera vers la même interface en Phase 2.
   - plugin JointStatePublisher : publie les positions de tous les joints.
   - un JointPositionController par servo, topic /<servo>/position,
     mêmes noms que les servos du code (neck, left_arm, right_arm,
     left_eye, right_eye).
   - friction quasi nulle sur la roue folle (sphère glissante).

  L'include est relatif : le fichier reste traitable par le xacro pip
  des tests unitaires, sans environnement ament.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dadou_robot">

  <xacro:include filename="dadou_robot.urdf.xacro"/>

  <!-- LED : joints fixes qu'il ne faut PAS laisser "lumper" par la conversion
       URDF->SDF (sinon leurs visuals fusionnent dans le lien parent, avec un nom
       du style "base_link_fixed_joint_lump__torso_link_visual_2" imprévisible).
       preserveFixedJoint garde <link>_visual comme visual distinct, avec un nom
       stable pour le bridge MaterialColor (voir robot_sim/scripts/leds_sim_node
       + config/gz_bridge.yaml).
       Les yeux ont désormais une COQUE (cloche en cylindres étagés) en plus de
       leur matrice : leur matrice a donc son propre link, comme le corps et la
       bouche, au lieu de compter sur "le seul visual du link œil". -->
  <gazebo reference="body_leds_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="mouth_leds_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="left_eye_leds_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="right_eye_leds_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <!-- ======== Caméra embarquée (SIM-ONLY, retour vidéo du pont web W3) ========
       Petit link fixe à l'avant de la tête (tambour neck), regardant vers +x
       (l'avant du robot) : la caméra suit donc le regard du cou, comme le fera
       la webcam vision sur le vrai robot. preserveFixedJoint pour que camera_link
       ne soit PAS fusionné dans head_link à la conversion URDF vers SDF (même
       piège que les LED) ; sinon la référence gazebo du capteur ne trouverait
       plus son link et la caméra ne serait pas montée. -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.03 0.05 0.03"/></geometry>
      <material name="black"/>
    </visual>
    <xacro:box_inertial m="0.05" x="0.03" y="0.05" z="0.03"/>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="head_link"/>
    <child link="camera_link"/>
    <!-- SUR LE DESSUS de la tête, légèrement en avant : la face avant du tambour
         est maintenant occupée par la matrice LED "bouche" (mouth_leds_link), et
         c'est aussi là qu'est la vraie caméra du robot (posée sur la tête, cf.
         validation du gaze du 2026-07-12). Elle regarde toujours vers +x et suit
         donc le cou. Seul consommateur : le retour vidéo web — le suivi de
         personne, lui, consomme /vision/person_box, pas cette image. -->
    <origin xyz="${head_radius/2} 0 ${head_height + 0.025}"/>
  </joint>
  <gazebo reference="camera_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <!-- Capteur caméra gz. La caméra gz regarde le long de +x du link : orientée
       vers l'avant sans rotation. <topic> EXPLICITE (camera/image_raw) pour ne
       PAS dépendre du nom auto-généré scoppé sur le monde/modèle
       (/world/stage/model/.../sensor/.../image) ; le bridge (gz_bridge.yaml)
       s'y abonne tel quel. NB : le rendu caméra exige le système gz Sensors,
       ajouté au monde stage.sdf (sans lui, aucune image n'est publiée). -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>15</update_rate>
      <topic>camera/image_raw</topic>
    </sensor>
  </gazebo>

  <!-- Roue folle : elle est modélisée en sphère fixe, elle doit glisser. -->
  <gazebo reference="caster_rear_link">
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
  </gazebo>

  <!-- Pneus : bonne adhérence pour que le différentiel morde. -->
  <gazebo reference="wheel_left_link">
    <mu1>1.2</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="wheel_right_link">
    <mu1>1.2</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo>
    <!-- Base différentielle : mêmes wheel_separation/wheel_radius que
         robot/move/diff_drive.py (propriétés xacro partagées). -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf_gz</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
      <!-- Un robot de 50 kg au milieu d'acteurs n'accélère pas comme un jouet. -->
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>

    <!-- Servos : un contrôleur en position par joint, piloté en vitesse
         (use_velocity_commands : stable sans réglage de PID). -->
    <xacro:macro name="servo_controller" params="joint">
      <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
        <joint_name>${joint}</joint_name>
        <topic>/${joint}/position</topic>
        <use_velocity_commands>true</use_velocity_commands>
      </plugin>
    </xacro:macro>
    <xacro:servo_controller joint="neck"/>
    <xacro:servo_controller joint="left_arm"/>
    <xacro:servo_controller joint="right_arm"/>
    <xacro:servo_controller joint="left_eye"/>
    <xacro:servo_controller joint="right_eye"/>
  </gazebo>

</robot>
